{
    "compilerOptions": {
        "rootDir": "./src",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "target": "ES2017",
        "lib": [
            "ES2021",
            "DOM"
        ],
        "module": "ESNext",
        "strict": true,
        "jsx": "react",
        "isolatedModules": true
    },
    "include": [
        "./src/**/*"
    ],
    "exclude": [
        "node_modules",
        "react",
        "react-compat",
        "mobx",
        "dist",
        "tests"
    ]
}